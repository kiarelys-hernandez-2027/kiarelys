#escribir un programa que cree un diccionario simulando una cesta de la compra. el programa debe preguntar el articulo y su precio y añadir el par al diccionario, hasta que el usuario decida terminar. despues de debe mostrar por pantalla la lista de la compra y el costo total, con el siguente formato producto|precio total: 3.15

cesta= {}
print ("Que articulo quieres llevar y su valor(escribe 'fin' para terminar): ")
   
while True:
    articulo = input("Artículo: ").lower()

    if articulo == "fin":
        break

    precio = float(input(f"Precio de {articulo}: "))
    
    cesta[articulo] = precio

print("lista de compra: ")
total = 0
print(f"\n {articulo} | {precio}")

for articulo, precio in cesta.items():
    print(f"{articulo} | {precio:.2f}")
    total += precio

print(f"\n Total: {total:.2f}")
